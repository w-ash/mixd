# =============================================================================
# Narada Configuration
# =============================================================================
#
# Copy this file to .env and fill in required values.
# For nested settings, use double-underscore syntax: API__LASTFM_BATCH_SIZE=100
#
# .env.local (if present) takes priority over .env for local overrides.

# =============================================================================
# Spotify Credentials (required for Spotify features)
# =============================================================================
# Create an app at https://developer.spotify.com/dashboard

SPOTIFY_CLIENT_ID=your_client_id
SPOTIFY_CLIENT_SECRET=your_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback
# Hosted (Fly.io): override for web OAuth callback
# SPOTIFY_REDIRECT_URI=https://your-app.fly.dev/auth/spotify/callback

# =============================================================================
# Last.fm Credentials (required for scrobble history and play counts)
# =============================================================================
# Create an app at https://www.last.fm/api/account/create
# Web auth (hosted): only api_key + secret needed — session key obtained via
# /auth/lastfm/callback flow, no password required.
# CLI auth: password is used for auth.getMobileSession, then persisted.

LASTFM_KEY=your_lastfm_key
LASTFM_SECRET=your_lastfm_secret
LASTFM_USERNAME=your_lastfm_username
LASTFM_PASSWORD=your_lastfm_password

# =============================================================================
# Database (PostgreSQL required)
# =============================================================================
# Pool and engine settings are managed in db_connection.py.
# Start local PG: docker compose up -d

# Local Docker:
DATABASE_URL=postgresql+psycopg://narada:narada@localhost:5432/narada
# Neon (managed, free tier — use the pooler endpoint):
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# =============================================================================
# Logging (optional — sensible defaults provided)
# =============================================================================
# Valid levels: TRACE, DEBUG, INFO, SUCCESS, WARNING, ERROR, CRITICAL

# CONSOLE_LOG_LEVEL=INFO
# FILE_LOG_LEVEL=DEBUG
# LOG_FILE=narada.log

# =============================================================================
# Server (optional — sensible defaults provided)
# =============================================================================
# SERVER__HOST=0.0.0.0        # Bind address (0.0.0.0 for Docker, 127.0.0.1 for local)
# SERVER__PORT=8000            # Server port
# SERVER__CORS_ORIGINS=["http://localhost:5173"]

# =============================================================================
# API Tuning (optional — defaults work well)
# =============================================================================

# API__LASTFM_RATE_LIMIT=4.5                        # requests/sec, must be > 0
# API__SPOTIFY_MARKET=US                             # ISO 3166-1 alpha-2 code
# IMPORT_SETTINGS__PLAY_THRESHOLD_PERCENTAGE=0.5     # 0.0-1.0
