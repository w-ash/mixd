{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "generate": "orval",
    "sync-api": "cd .. && uv run export-openapi && cd web && orval",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:auth": "playwright test --config playwright-auth.config.ts",
    "test:e2e:audit": "playwright test --config playwright-audit.config.ts",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "format:check": "biome format src/",
    "check": "biome check src/ && tsc",
    "lint:dead": "knip"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@faker-js/faker": "^10.5.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "knip": "^6.23.0",
    "msw": "^2.14.6",
    "orval": "^8.19.0",
    "shadcn": "^4.12.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.2",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@jalez/react-flow-smart-edge": "^4.0.0",
    "@neondatabase/auth": "0.4.2-beta",
    "@tanstack/react-query": "^5.101.2",
    "@xyflow/react": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "elkjs": "^0.11.1",
    "eventsource-parser": "^3.1.0",
    "lucide-react": "^1.22.0",
    "radix-ui": "^1.6.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-error-boundary": "^6.1.2",
    "react-router": "^8.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "imports": {
    "#/*": "./src/*"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
