          "name": {
            "type": "string",
            "title": "Name"
          }
        },
        "type": "object",
        "required": [
          "name"
        ],
        "title": "ArtistSchema",
        "description": "Artist representation in API responses."
      },
      "ConnectorStatusSchema": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "connected": {
            "type": "boolean",
            "title": "Connected"
          },
          "account_name": {
            "anyOf": [
