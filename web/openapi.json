        "properties": {
          "data": {
            "items": {
              "$ref": "#/components/schemas/PlaylistSummarySchema"
            },
            "type": "array",
            "title": "Data"
          },
          "total": {
            "type": "integer",
            "title": "Total"
          },
          "limit": {
            "type": "integer",
            "title": "Limit"
          },
          "offset": {
            "type": "integer",
            "title": "Offset"
