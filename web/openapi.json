            "type": "integer",
            "title": "Id"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Description"
          },
          "track_count": {
            "type": "integer",
            "title": "Track Count"
          },
          "connector_links": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Connector Links"
          },
          "updated_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
