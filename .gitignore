###################
# Python Related  #
###################
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/

# Testing and coverage
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/

# Package management (uv.lock and .python-version are committed)

###################
# IDEs & Editors  #
###################
# VS Code
.vscode/

# JetBrains
.idea/

# Vim
*.swp
*.swo

# Sublime Text
*.sublime-*

# Obsidian
.obsidian/

# Misc editor files
*~

###################
# OS Generated    #
###################
# macOS
.DS_Store

# Windows
Thumbs.db

###################
# Databases       #
###################
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
/data/db/*.db

###################
# Secrets & Auth  #
###################
.env
.env.*
!.env.example
.spotify_cache
*.token
*.key
*.pem
*.p12

# Alembic (keep migrations + config; ignore only caches)
alembic/versions/__pycache__/

###################
# Logs            #
###################
*.log
logs/
/data/logs/**/*.log

###################
# Node / Frontend #
###################
node_modules/
web/dist/

###################
# Tool Artifacts  #
###################
.playwright-mcp/

###################
# Project-specific #
###################
var/
data/
