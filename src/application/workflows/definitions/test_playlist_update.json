{
  "id": "test_playlist_update",
  "name": "End-to-End Playlist Update Test",
  "description": "Comprehensive test: Remove 10 tracks, lightly shuffle additional tracks, add 10 tracks, sort by title, update Spotify with differential operations. Starts with 98 tracks, ends with 98 tracks.",
  "version": "2.0",
  "tasks": [
    {
      "id": "source_original_playlist",
      "type": "source.playlist",
      "config": {
        "playlist_id": "5eoUfJYe0UAGbNjeG8HOLx",
        "connector": "spotify"
      }
    },
    {
      "id": "source_additional_tracks",
      "type": "source.playlist",
      "config": {
        "playlist_id": "2bYLt594RT2cv0gqeolIx4",
        "connector": "spotify"
      }
    },
    {
      "id": "select_tracks_to_remove",
      "type": "selector.limit_tracks",
      "config": {
        "count": 10,
        "method": "first"
      },
      "upstream": [
        "source_original_playlist"
      ]
    },
    {
      "id": "shuffle_additional_tracks",
      "type": "sorter.weighted_shuffle",
      "config": {
        "shuffle_strength": 0.2
      },
      "upstream": [
        "source_additional_tracks"
      ]
    },
    {
      "id": "select_tracks_to_add",
      "type": "selector.limit_tracks",
      "config": {
        "count": 10,
        "method": "first"
      },
      "upstream": [
        "shuffle_additional_tracks"
      ]
    },
    {
      "id": "remove_selected_tracks",
      "type": "filter.by_tracks",
      "config": {
        "exclusion_source": "select_tracks_to_remove"
      },
      "upstream": [
        "source_original_playlist",
        "select_tracks_to_remove"
      ]
    },
    {
      "id": "add_new_tracks",
      "type": "combiner.concatenate_playlists",
      "config": {
        "order": [
          "remove_selected_tracks",
          "select_tracks_to_add"
        ]
      },
      "upstream": [
        "remove_selected_tracks",
        "select_tracks_to_add"
      ]
    },
    {
      "id": "sort_by_track_title",
      "type": "sorter.by_metric",
      "config": {
        "metric_name": "title",
        "reverse": false
      },
      "upstream": [
        "add_new_tracks"
      ]
    },
    {
      "id": "update_spotify_playlist",
      "type": "destination.update_playlist",
      "config": {
        "playlist_id": "5eoUfJYe0UAGbNjeG8HOLx",
        "connector": "spotify",
        "append": false,
        "dry_run": false
      },
      "upstream": [
        "sort_by_track_title"
      ]
    }
  ]
}