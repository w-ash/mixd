{
  "id": "template_test",
  "name": "Template Naming Test",
  "description": "Test workflow demonstrating template-based playlist naming",
  "version": "1.0",
  "tasks": [
    {
      "id": "source_liked_songs",
      "type": "source.playlist",
      "config": {
        "playlist_id": "YOUR_LIKED_SONGS_PLAYLIST_ID",
        "connector": "spotify"
      }
    },
    {
      "id": "limit_for_testing",
      "type": "selector.limit_tracks",
      "config": {
        "count": 10,
        "method": "first"
      },
      "upstream": ["source_liked_songs"]
    },
    {
      "id": "create_templated_playlist",
      "type": "destination.create_playlist",
      "config": {
        "name": "Test Playlist - {date}",
        "description": "Created on {datetime} with {track_count} tracks. Generated at {time}.",
        "connector": "spotify"
      },
      "upstream": ["limit_for_testing"]
    }
  ]
}
