{
  "id": "test_spotify_popularity_sort",
  "name": "Test Spotify Popularity Sort",
  "description": "Small test workflow to verify spotify_popularity metrics flow from source to sort",
  "version": "1.0",
  "tasks": [
    {
      "id": "source_altar",
      "type": "source.playlist",
      "config": {
        "playlist_id": "2orOfUrshU959tYCUjt0Zs",
        "connector": "spotify"
      }
    },
    {
      "id": "limit_altar",
      "type": "selector.limit_tracks",
      "config": {
        "count": 30,
        "method": "first"
      },
      "upstream": [
        "source_altar"
      ]
    },
    {
      "id": "source_release_radar",
      "type": "source.playlist",
      "config": {
        "playlist_id": "00U3FfaARqbWZAYKvjyGjh",
        "connector": "spotify"
      }
    },
    {
      "id": "limit_release_radar",
      "type": "selector.limit_tracks",
      "config": {
        "count": 30,
        "method": "first"
      },
      "upstream": [
        "source_release_radar"
      ]
    },
    {
      "id": "combine_playlists",
      "type": "combiner.concatenate_playlists",
      "config": {
        "order": [
          "limit_altar",
          "limit_release_radar"
        ]
      },
      "upstream": [
        "limit_altar",
        "limit_release_radar"
      ]
    },
    {
      "id": "enrich_spotify_popularity",
      "type": "enricher.spotify",
      "config": {
        "metrics": [
          "spotify_popularity"
        ]
      },
      "upstream": [
        "combine_playlists"
      ]
    },
    {
      "id": "sort_by_popularity",
      "type": "sorter.by_metric",
      "config": {
        "metric_name": "spotify_popularity",
        "reverse": true
      },
      "upstream": [
        "enrich_spotify_popularity"
      ]
    },
    {
      "id": "destination",
      "type": "destination.create_playlist",
      "config": {
        "name": "Test Spotify Popularity Sort",
        "description": "Test playlist for verifying spotify_popularity metrics flow",
        "connector": "spotify"
      },
      "upstream": [
        "sort_by_popularity"
      ]
    }
  ]
}