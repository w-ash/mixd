{
  "id": "hidden_gems",
  "name": "Hidden Gems Discovery",
  "description": "Find tracks you loved but haven't played recently - rediscover forgotten favorites",
  "version": "1.0",
  "tasks": [
    {
      "id": "source_liked_songs",
      "type": "source.liked_tracks",
      "config": {
        "connector_filter": "spotify"
      }
    },
    {
      "id": "enrich_play_history",
      "type": "enricher.play_history",
      "config": {
        "metrics": ["total_plays", "last_played_dates"],
        "period_days": 365
      },
      "upstream": ["source_liked_songs"]
    },
    {
      "id": "filter_hidden_gems",
      "type": "filter.by_play_history",
      "config": {
        "min_plays": 3,
        "min_days_back": 180,
        "include_missing": false
      },
      "upstream": ["enrich_play_history"]
    },
    {
      "id": "sort_by_total_plays",
      "type": "sorter.by_play_history",
      "config": {
        "reverse": true
      },
      "upstream": ["filter_hidden_gems"]
    },
    {
      "id": "limit_selection",
      "type": "selector.limit_tracks",
      "config": {
        "count": 25,
        "method": "first"
      },
      "upstream": ["sort_by_total_plays"]
    },
    {
      "id": "create_hidden_gems_playlist",
      "type": "destination.create_playlist",
      "config": {
        "name": "Hidden Gems",
        "description": "Forgotten favorites: tracks with 3+ plays but not touched in 6+ months",
        "connector": "spotify"
      },
      "upstream": ["limit_selection"]
    }
  ]
}